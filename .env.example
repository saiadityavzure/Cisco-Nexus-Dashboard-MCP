# ─── NDFC Connection ─────────────────────────────────────────────────────────
NDFC_HOST=https://your-ndfc-host-or-ip
NDFC_USERNAME=admin
NDFC_API_KEY=your-api-key-here          # preferred auth method
NDFC_PASSWORD=                          # fallback if no API key
NDFC_VERIFY_SSL=true

# ─── ND Compatibility Aliases ─────────────────────────────────────────────────
ND_URL=https://your-ndfc-host-or-ip
ND_USERNAME=admin
ND_VERIFY_SSL=true

# ─── Transport ────────────────────────────────────────────────────────────────
# "stdio"  → run as a subprocess (Claude Desktop / VS Code extension)
# "http"   → run as an HTTP server (Docker / remote)
TRANSPORT=stdio

# ─── HTTP Server (only used when TRANSPORT=http) ─────────────────────────────
HOST=0.0.0.0
PORT=9007

# ─── MCP Transport Security (HTTP/SSE Host/Origin Validation) ───────────────
# Comma-separated values. Add every host header your clients/proxy will send.
# Examples:
# ALLOWED_HOSTS=10.20.1.119:9007,localhost:9007,127.0.0.1:9007
# ALLOWED_ORIGINS is optional; if omitted, origins are auto-derived from ALLOWED_HOSTS.
ENABLE_DNS_REBINDING_PROTECTION=true
ALLOWED_HOSTS=
ALLOWED_ORIGINS=

# ─── SSH / NX-API Switch Access ───────────────────────────────────────────────
SSH_USERNAME=admin
SSH_PASSWORD=your-switch-password
SSH_TIMEOUT=30

# ─── NX-API Defaults ─────────────────────────────────────────────────────────
NXAPI_PORT=443
NXAPI_VERIFY_SSL=false

# ─── Feature Flags ────────────────────────────────────────────────────────────
# Set to false to disable potentially destructive tool groups
ENABLE_EXECUTION_TOOLS=true
ENABLE_TROUBLESHOOTING_TOOLS=true
ENABLE_WRITE_TOOLS=true
